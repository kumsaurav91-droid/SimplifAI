# ══════════════════════════════════════════════════════════════
#   SimplifAI — .gitignore
#   AWS AI for Bharat Hackathon 2026 · Team AI²
#   ⚠️  This file protects secrets & reduces repo noise
# ══════════════════════════════════════════════════════════════


# ─────────────────────────────────────
# 🔒 SECRETS & CREDENTIALS — CRITICAL
# ─────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
.env.test
.env*.local
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
aws-credentials
.aws/
secrets.json
credentials.json


# ─────────────────────────────────────
# 📦 NODE DEPENDENCIES
# ─────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/


# ─────────────────────────────────────
# 🧪 TEST OUTPUTS & COVERAGE
# ─────────────────────────────────────
coverage/
.nyc_output/
test-results/
*.test-output.json


# ─────────────────────────────────────
# 🏗️ BUILD & DIST ARTIFACTS
# ─────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
*.min.js
*.min.css
*.bundle.js
*.chunk.js


# ─────────────────────────────────────
# 🖥️ OS GENERATED FILES
# ─────────────────────────────────────

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon?

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*


# ─────────────────────────────────────
# 💻 IDE & EDITOR FILES
# ─────────────────────────────────────

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# Sublime Text
*.sublime-project
*.sublime-workspace


# ─────────────────────────────────────
# 📋 LOGS
# ─────────────────────────────────────
logs/
*.log
*.log.*
npm-debug.log
server.log
error.log
combined.log
access.log
pm2.log


# ─────────────────────────────────────
# ☁️ AWS & CLOUD DEPLOYMENT
# ─────────────────────────────────────
.serverless/
.aws-sam/
samconfig.toml
cdk.out/
terraform.tfstate
terraform.tfstate.backup
*.tfvars
.terraform/


# ─────────────────────────────────────
# 📁 TEMP & RUNTIME FILES
# ─────────────────────────────────────
tmp/
temp/
.tmp/
.temp/
*.tmp
*.temp
*.bak
*.backup
*.orig
*.pid
.pid


# ─────────────────────────────────────
# 📊 GENERATED REPORTS & OUTPUTS
# ─────────────────────────────────────
*.pdf
reports/
output/


# ─────────────────────────────────────
# 🔧 MISC TOOLING
# ─────────────────────────────────────
.eslintcache
.stylelintcache
.parcel-cache
.cache/
.turbo/
.vercel/
.netlify/
